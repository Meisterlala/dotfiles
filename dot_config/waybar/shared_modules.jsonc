{
  "wlr/taskbar": {
    "format": "{icon} {title:.45}",
    "icon-size": 30,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "com.mitchellh.ghostty"],
  },

  "hyprland/window": {
    "format": "{title}",
    "icon": false,
    "rewrite": {
      "(.*) ŌĆö Zen Browser": "$1",
      "class<com.mitchellh.ghostty>": "Ņ¬ģ Ghostty",
    },
    "separate-outputs": true,
  },

  "custom/updates": {
    "format": "{} {icon}",
    "return-type": "json",
    "format-icons": {
      "updates": "¾▒ŹĘ",
      "normal": "¾▒ŹĘ",
      "warning": "¾▒ŹĘ",
      "critical": "¾▒ŹĘ",
      "updated": "¾░Æś",
      "error": "’ü¬",
    },
    "exec": "~/.config/waybar/arch_updates.py",
    "interval": 900,
    "signal": 13,
    "escape": false,
    "hide-empty-text": true,
    "on-click": "ghostty -e bash -lc 'paru -Syu; echo; read -rp \"Press Enter to close...\"'",
    "on-click-right": "pkill -RTMIN+13 waybar",
  },

  "custom/scrcpy-active": {
    "exec": "~/.config/waybar/scrcpy-active.sh",
    "on-click": "~/.config/waybar/scrcpy-active.sh --kill",
    "hide-empty-text": true,
    "interval": 2,
  },

  "custom/fritz-traffic": {
    "return-type": "json",
    "exec": "~/.config/waybar/fritz_traffic.py",
    "interval": 10,
    "tooltip": true,
    "hide-empty-text": true,
    "signal": 14,
    "on-click": "pkill -RTMIN+14 waybar",
  },

  "custom/garage-longhorn": {
    "exec": "~/.config/waybar/garage-status.sh longhorn-backup L",
    "interval": 10,
    "return-type": "json",
    "hide-empty-text": true,
  },

  "custom/garage-velero": {
    "exec": "~/.config/waybar/garage-status.sh velero V",
    "interval": 10,
    "return-type": "json",
    "hide-empty-text": true,
  },

  "tray": {
    "icon-size": 20,
    "spacing": 10,
  },

  "cpu": {
    "tooltip": true,
    "interval": 3,
    "format": "{usage:>2}% ’ŗø",
  },

  "memory": {
    "format": "{percentage:>2}% ’āē",
  },

  "load": {
    "interval": 10,
    "format": "{load1:.1f} {load5:.1f} {load15:.1f}",
  },

  "wireplumber": {
    "format": "{volume}% {icon} ",
    "format-muted": "¾░¢ü",
    "max-volume": 200,
    "scroll-step": 2.5,
    "on-click": "pwvucontrol",
    "on-click-right": "helvum",
    "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "format-icons": ["’Ć”", "’Ć¦", "’Ć©"],
  },

  "clock": {
    "locale": "de_DE.UTF-8",
    "format": "{:%H:%M} ’ĆŚ",
    "format-alt": "{:%A %d.%m.%Y  %H:%M} ’ĆŚ",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-right": "mode",
    },
  },

  "privacy": {
    "icon-spacing": 4,
    "icon-size": 18,
    "transition-duration": 250,
    "modules": [
      {
        "type": "screenshare",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },
      {
        "type": "audio-in",
        "tooltip": true,
        "tooltip-icon-size": 24,
      },
    ],
    "ignore": [
      {
        "type": "audio-in",
        "name": "cava",
      },
      {
        "type": "screenshare",
        "name": "obs",
      },
      {
        "type": "audio-in",
        "name": "discord_capture",
      },
      {
        "type": "audio-in",
        "name": "ALSA plug-in [python3.14]",
      },
    ],
  },

  "custom/systemd-failed-units": {
    "return-type": "json",
    "exec": "~/.config/waybar/failed-units.sh",
    "interval": 10,
    "signal": 10,
    "hide-empty-text": true,
    "on-click": "~/.config/waybar/restart-failed.sh",
  },

  "custom/k8s-alerts": {
    "return-type": "json",
    "exec": "~/.config/waybar/k8s-alerts.py",
    "interval": 60,
    "tooltip": true,
    "escape": false,
    "hide-empty-text": true,
    "signal": 12,
    "on-click": "pkill -RTMIN+12 waybar",
  },

  "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon}</span>",
    "format-icons": {
      "notification": "¾▒ģ½",
      "none": "¾░é£",
      "dnd-notification": "¾░éĀ",
      "dnd-none": "¾░¬ō",
      "inhibited-notification": "¾░éø",
      "inhibited-none": "¾░¬æ",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░¬æ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },

  // "custom/daily-plan": {
  //   "return-type": "json",
  //   "exec": "/home/misti/opencode/4week/waybar_daily_plan.py",
  //   "interval": 30,
  //   "signal": 12,
  //   "format": "{text}",
  //   "tooltip": true,
  //   "on-click": "/home/misti/opencode/4week/daily_plan_window.py",
  //   "escape": false,
  // },

  "custom/habits": {
    "return-type": "json",
    "exec": "/home/misti/.local/bin/habits-waybar",
    "format": "{text}",
    "interval": 30,
    "tooltip": true,
    "on-click": "/home/misti/.local/bin/habits-waybar --toggle",
    "escape": false,
  },

  "gamemode": {
    "format": "{glyph}",
    "format-alt": "{glyph} {count}",
    "glyph": "’×│",
    "hide-not-running": true,
    "use-icon": true,
    "icon-name": "input-gaming-symbolic",
    "icon-spacing": 4,
    "icon-size": 20,
    "tooltip": true,
    "tooltip-format": "Games running: {count}",
  },

  "custom/sleep": {
    "format": "’åå",
    "tooltip": "Suspend",
    "on-click": "systemctl suspend",
    "interval": 100,
  },

  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "exec-if": "which wttrbar",
    "exec": "wttrbar --location Frankfurt --hide-conditions --lang de",
    "return-type": "json",
  },

  "custom/gpu": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits",
    "format": "{:>2}% ¾░ó«",
    "interval": 5,
  },

  "custom/hypridle": {
    "format": "{} ¾░Æ▓",
    "hide-empty-text": true,
    "return-type": "json",
    "exec": "~/.config/waybar/idle_inhibit.py",
    "interval": 5,
  },

  "custom/weight": {
    "return-type": "json",
    "exec": "/home/misti/opencode/weight-unlock/show_weight_waybar.py",
    "on-click": "/home/misti/opencode/weight-unlock/show_weight_waybar.py --toggle; pkill -RTMIN+11 waybar",
    "tooltip": true,
    "interval": 60,
    "signal": 11,
  },

  "custom/claude": {
    "format": "{} ¾░Ł╗",
    "return-type": "json",
    "interval": 300,
    "hide-empty-text": true,
    "exec": "~/.config/waybar/claude_usage.py",
    "on-click": "pkill -RTMIN+8 waybar",
    "signal": 8,
  },

  "custom/codex": {
    "format": "{} ¾▒Ö║",
    "return-type": "json",
    "interval": 300,
    "hide-empty-text": true,
    "exec": "~/.config/waybar/codex_usage.py",
    "on-click": "pkill -RTMIN+9 waybar",
    "signal": 9,
  },
}
