// -*- mode: jsonc -*-
[
  {
    // Main
    "include": [
      "~/.config/waybar/shared_modules.jsonc",
      "~/.config/waybar/hyprland-workspaces.jsonc",
    ],
    "height": 38,
    "spacing": 4,
    "fixed-center": true,
    "reload_style_on_change": false,
    "layer": "top",
    "output": "DP-3",

    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": [
      "custom/notification",
      "privacy",
      "tray",
      "custom/fritz-traffic",
      "custom/nvidia-driver",
      "custom/systemd-failed-units",
      "gamemode",
      "custom/scrcpy-active",
      "custom/updates",
      //"custom/claude",
      "custom/codex",
      "custom/habits",
      "wireplumber",
      "custom/daily-plan",
      "clock",
    ],
  },
  {
    // Secondary
    "include": [
      "~/.config/waybar/shared_modules.jsonc",
      "~/.config/waybar/hyprland-workspaces.jsonc",
    ],
    "height": 38,
    "spacing": 4,
    "fixed-center": true,
    "reload_style_on_change": false,
    "layer": "top",
    "output": "DP-2",

    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": [
      "load",
      "custom/hypridle",
      "custom/gpu",
      "cpu",
      "memory",
      "custom/k8s-alerts",
      "custom/weight",
      "custom/sleep",
      "custom/garage-longhorn",
      "custom/garage-velero",
      "custom/garage-kopia",
      "clock",
    ],
  },
]
