Documentation=man:systemd.service(5)
After=graphical-session.target xdg-desktop-autostart.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=/home/misti/.local/bin/thunderbird-xwayland
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
