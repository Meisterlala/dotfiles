{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",

  "small_model": "github-copilot/gpt-4o",

  "agent": {
    "commit-review": {
      "description": "Review the current staged git changes. Provide feedback on code quality, style, and potential issues.",
      "prompt": "You are a senior software engineer reviewing the following git changes. Provide constructive feedback on code quality, style, and potential issues. Suggest improvements where necessary.",
      "permission": {
        "write": "ask",
        "edit": "ask"
      }
    }
  },

  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:e2b": {
          "name": "Gemma 4 E2B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:e4b": {
          "name": "Gemma 4 E4B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:26b": {
          "name": "Gemma 4 26B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "cerebro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebro Arbeit",
      "options": {
        "baseURL": "https://chat.cerebroai.de/api"
      },
      "models": {
        "gpt-5.2": {
          "name": "gpt-5.2",
          "limit": {
            "context": 400000,
            "output": 100000
          },
          "options": {
            "reasoningSummary": false
          },
          "reasoning": false,
          "tool_call": true
        },
        "gemini-2.5-flash": {
          "name": "gemini-2.5-flash",
          "limit": {
            "context": 400000,
            "output": 100000
          },
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  },

  "plugin": ["cc-safety-net"],

  "mcp": {
    "browsermcp": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "@browsermcp/mcp@latest"]
    },
    "livekit-docs": {
      "enabled": false,
      "type": "remote",
      "url": "https://docs.livekit.io/mcp"
    },
    "kubernetes": {
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest"]
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    }
  },

  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "ask",
      "~/.config/nvim/tmp/**": "allow"
    },

    "bash": {
      "*": "ask",
      "sudo*": "deny",

      "./scripts/*": "allow",

      "awk *": "allow",
      "cat *": "allow",
      "cd *": "allow",
      "cut *": "allow",
      "curl *": "allow",
      "date *": "allow",
      "dig *": "allow",
      "file *": "allow",
      "find *": "allow",
      "flux check *": "allow",
      "flux get *": "allow",
      "flux logs *": "allow",
      "flux reconcile *": "allow",

      "getent *": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",

      "go mod tidy": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "grep *": "allow",
      "gunzip *": "allow",
      "gzip *": "allow",

      "head *": "allow",
      "helm get *": "allow",
      "helm link *": "allow",
      "helm list *": "allow",
      "helm repo *": "allow",
      "helm show *": "allow",
      "helm status *": "allow",
      "history *": "allow",
      "htop": "allow",
      "hubble *": "allow",

      "ip *": "allow",
      "jq *": "allow",

      "kubectl -n * api-resources *": "allow",
      "kubectl -n * auth can-i *": "allow",
      "kubectl -n * debug *": "allow",
      "kubectl -n * describe *": "allow",
      "kubectl -n * diff *": "allow",
      "kubectl -n * events *": "allow",
      "kubectl -n * explain *": "allow",
      "kubectl -n * get *": "allow",
      "kubectl -n * logs *": "allow",
      "kubectl -n * port-forward *": "allow",
      "kubectl -n * top *": "allow",
      "kubectl --namespace * api-resources *": "allow",
      "kubectl --namespace * auth can-i *": "allow",
      "kubectl --namespace * debug *": "allow",
      "kubectl --namespace * describe *": "allow",
      "kubectl --namespace * diff *": "allow",
      "kubectl --namespace * events *": "allow",
      "kubectl --namespace * explain *": "allow",
      "kubectl --namespace * get *": "allow",
      "kubectl --namespace * logs *": "allow",
      "kubectl --namespace * port-forward *": "allow",
      "kubectl --namespace * top *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl auth can-i *": "allow",
      "kubectl debug *": "allow",
      "kubectl describe *": "allow",
      "kubectl diff *": "allow",
      "kubectl events *": "allow",
      "kubectl explain *": "allow",
      "kubectl get *": "allow",
      "kubectl logs *": "allow",
      "kubectl port-forward *": "allow",
      "kubectl top *": "allow",

      "kustomize build *": "allow",

      "ls *": "allow",
      "mkdir *": "allow",

      "nslookup *": "allow",
      "ping *": "allow",
      "pwsh -NoProfile ./scripts/validate.ps1": "allow",

      "pnpm *": "allow",
      "ps *": "allow",

      "realpath *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sleep *": "allow",
      "sort *": "allow",
      "ss *": "allow",
      "stat *": "allow",
      "ssh baldr *": "allow",
      "ssh odin *": "allow",
      "ssh ran *": "allow",
      "ssh raspberry-pi *": "allow",
      "ssh raspberrypi *": "allow",

      "tail *": "allow",
      "tar *": "allow",
      "top *": "allow",
      "touch *": "allow",
      "tr *": "allow",
      "tree *": "allow",

      "uniq *": "allow",
      "unzip *": "allow",
      "unzstd *": "allow",

      "wc *": "allow",

      "xargs *": "allow",

      "yq *": "allow",

      "zstd *": "allow"
    }
  }
}
