      "flux logs *": "allow",
      "flux reconcile *": "allow",
      "getent *": "allow",
      "git branch *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "go mod tidy": "allow",
      "go test *": "allow",
      "gofmt *": "allow",
      "grep *": "allow",
      "gunzip *": "allow",
      "gzip *": "allow",
      "head *": "allow",
      "helm get *": "allow",
