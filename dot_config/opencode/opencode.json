{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "small_model": "openai/gpt-5.4-mini",
  "lsp": true,
  "agent": {
    "general": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "commit-review": {
      "model": "openai/gpt-5.4-mini",
      "description": "Review the current staged git changes. Provide feedback on code quality, style, and potential issues.",
      "prompt": "You are a senior software engineer reviewing the following git changes. Provide constructive feedback on code quality, style, and potential issues. Suggest improvements where necessary.",
      "permission": {
        "write": "ask",
        "edit": "ask"
      }
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.5:4b": {
          "name": "Qwen 3.5 4B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 65536,
            "output": 8192
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "gemma4:e2b": {
          "name": "Gemma 4 E2B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:e4b": {
          "name": "Gemma 4 E4B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 128000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:26b": {
          "name": "Gemma 4 26B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "gemma4:31b": {
          "name": "Gemma 4 31B",
          "tool_call": true,
          "reasoning": false,
          "limit": {
            "context": 256000,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    },
    "cerebro": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebro Arbeit",
      "options": {
        "baseURL": "https://chat.cerebroai.de/api"
      },
      "models": {
        "gpt-5.2": {
          "name": "gpt-5.2",
          "limit": {
            "context": 400000,
            "output": 100000
          },
          "options": {
            "reasoningSummary": false
          },
          "reasoning": false,
          "tool_call": true
        },
        "gemini-2.5-flash": {
          "name": "gemini-2.5-flash",
          "limit": {
            "context": 400000,
            "output": 100000
          },
          "reasoning": true,
          "tool_call": true
        }
      }
    }
  },
  "plugin": [
    "cc-safety-net@latest",
    "@plannotator/opencode@latest",
    // "oh-my-openagent@latest"
    "openviking-opencode-plugin@latest",
    "@prevalentware/opencode-goal-plugin"
  ],
  "mcp": {
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--no-usage-statistics",
        "--autoConnect"
      ]
    },
    "livekit-docs": {
      "enabled": false,
      "type": "remote",
      "url": "https://docs.livekit.io/mcp"
    },
    "kubernetes": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "kubernetes-mcp-server@latest"]
    },
    "thunderbird-mail": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "--package",
        "github:TKasperczyk/thunderbird-mcp",
        "thunderbird-mcp"
      ]
    },
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PAT}"
      }
    }
  },
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**"]
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "thunderbird-mail_*": "ask",
    "thunderbird-mail_getAccountAccess": "allow",
    "thunderbird-mail_listAccounts": "allow",
    "thunderbird-mail_getRecentMessages": "allow",
    "thunderbird-mail_searchMessages": "allow",
    "thunderbird-mail_getMessage": "allow",
    "thunderbird-mail_getMessages": "allow",
    "thunderbird-mail_displayMessage": "allow",
    "thunderbird-mail_listFolders": "allow",
    "thunderbird-mail_listFilters": "allow",
    "thunderbird-mail_searchContacts": "allow",
    "thunderbird-mail_listCalendars": "allow",
    "thunderbird-mail_listCategories": "allow",
    "thunderbird-mail_listEvents": "allow",
    "thunderbird-mail_listTasks": "allow",
    "external_directory": {
      "*": "ask",
      "~/.config/nvim/tmp/**": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "sudo*": "deny",
      "./*": "allow",
      "./scripts/*": "allow",
      "awk *": "allow",
      "cat *": "allow",
