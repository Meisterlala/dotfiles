      "gh pr view *": "allow",
      "gh search *": "allow",
      "zstd *": "allow",

      "cargo search *": "allow",
      "cargo clippy*": "allow",
      "cargo fmt*": "allow",
      "cargo test *": "allow",
      "cargo build *": "allow",
      "rustc *": "allow",
      "cargo info *": "allow",

      "woodpecker *": "allow",
      "skopeo inspect *": "allow"
    }
  }
}
