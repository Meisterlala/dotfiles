{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "none",
  "control-center-positionY": "none",
  "control-center-margin-top": 20,
  "control-center-margin-bottom": 20,
  "control-center-margin-right": 20,
  "control-center-margin-left": 20,
  "control-center-width": 800,
  "control-center-height": -1,
  "fit-to-screen": false,
  "layer-shell-cover-screen": false,

  "layer-shell": true,
  "layer": "overlay",
  "control-center-layer": "overlay",
  "cssPriority": "user",
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "notification-inline-replies": true,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-window-width": 800,
  "keyboard-shortcuts": true,
  "image-visibility": "always",
  "transition-time": 200,
  "hide-on-clear": true,
  "hide-on-action": true,
  "script-fail-notify": true,

  "widgets": ["inhibitors", "dnd", "buttons-grid", "mpris", "notifications"],
  "widget-config": {
    "notifications": {
      "vexpand": false
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": false,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 5,
      "text": "Label Text"
    },
    "mpris": {
      "autohide": true
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰒲 Inhibit Sleep",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && ~/.config/swaync/toggle-hypridle-inhibit.sh on || ~/.config/swaync/toggle-hypridle-inhibit.sh off'",
          "update-command": "sh -c '[[ -f /tmp/hypridle-inhibit.lock ]] && echo true || echo false'"
        },
        {
          "label": "󰍹 2nd Monitor Off",
          "type": "toggle",
          "active": false,
          "command": "sh -c '[[ $SWAYNC_TOGGLE_STATE == true ]] && ~/.config/swaync/toggle-second-monitor.sh disable || ~/.config/swaync/toggle-second-monitor.sh enable'",
          "update-command": "sh -c '[[ \"$(~/.config/swaync/toggle-second-monitor.sh status)\" == disabled ]] && echo true || echo false'"
        }
      ]
    }
  }
}
